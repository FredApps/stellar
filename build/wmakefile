# wmakefile - Open Watcom 16-bit real-mode DOS build for SHOOTER
# Usage (from project root, with WATCOM env set):  wmake -f build\wmakefile

CC   = wcc
# -bt=dos  target DOS   -ms/-mc memory model   -4 486 scheduling
# -ot optimise for time  -s no stack checks   -zq quiet   -oi inline
CFLAGS = -bt=dos -mc -4 -ot -s -zq -oi -zp1 -Isrc

OBJS = main.obj game.obj vga.obj input.obj sound.obj sprites.obj hiscore.obj bmpdump.obj

SHOOTER.EXE : $(OBJS)
	wlink FORMAT DOS NAME SHOOTER.EXE FILE {$(OBJS)} LIBPATH $(%WATCOM)\lib286\dos LIBPATH $(%WATCOM)\lib286 OPTION QUIET

main.obj    : src\main.c
	$(CC) $(CFLAGS) src\main.c
game.obj    : src\game.c
	$(CC) $(CFLAGS) src\game.c
vga.obj     : src\vga.c
	$(CC) $(CFLAGS) src\vga.c
input.obj   : src\input.c
	$(CC) $(CFLAGS) src\input.c
sound.obj   : src\sound.c
	$(CC) $(CFLAGS) src\sound.c
sprites.obj : src\sprites.c
	$(CC) $(CFLAGS) src\sprites.c
hiscore.obj : src\hiscore.c
	$(CC) $(CFLAGS) src\hiscore.c
bmpdump.obj : src\bmpdump.c
	$(CC) $(CFLAGS) src\bmpdump.c

clean : .SYMBOLIC
	-if exist *.obj del *.obj
	-if exist SHOOTER.EXE del SHOOTER.EXE
