# Local toolchains and emulator installs; soundtrack sources are versioned.
/tools/*
!/tools/music/
/tools/music/__pycache__/

# Open Watcom build output
/*.obj
/*.err
/*.map
/*.lnk
/SHOOTER.EXE
/STELLAR.EXE
/AYRIEN.EXE

# Verification output and runtime state
/TITLE.BMP
/FRAME.BMP
/HELP1.BMP
/HELP2.BMP
/HELP3.BMP
/HELP4.BMP
/HELP5.BMP
/HELP6.BMP
/STAGES.BMP
/BOSSES.BMP
/BOSSES1.BMP
/BOSSES2.BMP
/WIN.BMP
/AUDIO*.TXT
/BENCH.TXT
/SELFTEST.TXT
/web/web.config
/HISCORE.DAT

# Generated release artifacts
/dist/*.EXE
/dist/*.IMG
/dist/*.ZIP
/release/

# Local DOSBox configs contain machine-specific mount paths
/build/*.conf
/build/nobank/

# Local deployment and secret material
/.secrets/
/.ssh/
/.codex/
/.claude/
/.env
/.env.*
/App_Data/
/web/App_Data/
*.key
*.pem
*.p12
*.pfx
*.kdbx

# OS/editor noise
Thumbs.db
.DS_Store
*.swp
*.tmp
